From 24739fbc9d1efafe01af2498f2a42416255360de Mon Sep 17 00:00:00 2001
From: Zebastjan Johanzen <zebastian.johanzen@gmail.com>
Date: Tue, 24 Feb 2026 10:49:52 -0500
Subject: [PATCH 25/25] fix: use 'idle' instead of invalid 'initializing'
 pipeline_status

The database constraint only allows: idle, downloading, chunking,
embedding, summarizing, complete, error. Using 'initializing' caused
constraint violations (error code 23514) and prevented source creation,
making all crawls fail immediately.

Changed to 'idle' which is the database default and semantically
correct for a newly created source that hasn't started processing yet.

Co-Authored-By: Claude Sonnet 4.5 <noreply@anthropic.com>
---
 python/src/server/services/crawling/crawling_service.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/python/src/server/services/crawling/crawling_service.py b/python/src/server/services/crawling/crawling_service.py
index bd2ae6e893..f401e71db8 100644
--- a/python/src/server/services/crawling/crawling_service.py
+++ b/python/src/server/services/crawling/crawling_service.py
@@ -419,7 +419,7 @@ async def send_heartbeat_if_needed():
                                 "source_type": "url",
                                 "auto_generated": False,
                             },
-                            "pipeline_status": "initializing",
+                            "pipeline_status": "idle",
                         }
 
                         self.supabase_client.table("archon_sources").insert(minimal_source).execute()
