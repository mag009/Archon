+
+  if (!response.ok) {
+    throw new Error(`HTTP error! status: ${response.status}`);
+  }
+
+  return await response.json();
+}""",
+        "context_before": "Client-side user management utilities.",
+        "context_after": "Returns user object with profile data.",
