+  const [isDiscovering, setIsDiscovering] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+  
+  // Implementation follows usePolling patterns
+  // Error handling consistent with other hooks
+  
+  return {
+    peers,
+    isDiscovering, 
+    error,
+    startDiscovery,
