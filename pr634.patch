-# Find hard-coded ports
-grep -r ":8181\|:8051\|:8052\|:3737" src/ --include="*.ts" --include="*.tsx"
-
-# Find http:// references (should use protocol from env)
-grep -r "http://" src/ | grep -v "https://" | grep -v ".md"
-
